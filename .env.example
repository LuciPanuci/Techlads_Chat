# --- Client app / smoke test (scripts/test-edge.mjs) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Aliases used by test:edge (same values as above)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SITE_ID=default

# --- Supabase Edge Function secrets (set via `supabase secrets set`, NOT in .env) ---
# ANTHROPIC_API_KEY=sk-ant-...
# SITE_CHAT_ADMIN_SECRET=generate-a-long-random-secret
# RESEND_API_KEY=re_...                    # optional — inquiry email notifications
# SITE_CHAT_NOTIFY_EMAIL=you@example.com   # optional
# SITE_CHAT_FROM_EMAIL=onboarding@resend.dev

# Optional: include admin save step in smoke test
# SITE_CHAT_ADMIN_SECRET=your-long-random-secret
