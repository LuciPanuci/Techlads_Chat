# Dependencies
node_modules/

# Build output (published to npm via prepublishOnly; not tracked in git)
dist/

# WordPress bundles (regenerate with npm run build:wp)
wordpress/site-context-chat/assets/
!wordpress/site-context-chat/assets/.gitkeep
wordpress/site-context-chat.zip

# Environment & secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Logs & caches
*.log
npm-debug.log*
.npm
.cache/

# Supabase local/link artifacts (contain project refs and DB URLs)
supabase/.temp/
supabase/.branches/

# Local overrides
*.local
